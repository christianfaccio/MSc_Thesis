<?xml version="1.0"?>
<!--
    1 km × 1 km × 40 m coastal scenario (Abu Dhabi shelf scale).

    This mirrors config/simulation.xml but with the current parameters scaled to
    the km domain. The key change is the extended <vortex_currents> line, which
    now carries domain_size and length_scale so VortexField tiles over the whole
    1 km domain and produces ~200 m eddies instead of the legacy 100 m point-like
    swirls. SingleAgentEnv overrides these current values at reset(); this XML is
    primarily for direct visualization via scripts/plot_currents.py.
-->
<data>
    <!-- Mandatory Field: Define environment characteristics -->
    <environment_setup>

        <!-- Constant planar drift (tidal / geostrophic background), m/s -->
        <uniform_current> 0.05 0.05 </uniform_current>

        <!-- Random noise currents: Frequency [Hz], Intensity [m/s] -->
        <noise_currents> 0.5 0.05 </noise_currents>

        <!-- Vorticity field current (extended km form).
             Parameters: density  intensity[m/s]  domain_size[m]  length_scale[m]
               density       -> number of vortices spread over the domain
               domain_size   -> periodic tiling period (match the domain extent)
               length_scale  -> eddy radius; swirl speed peaks ~length_scale from
                                each centre. ~200 m gives a few resolved eddies. -->
        <vortex_currents> 20 0.15 1000.0 200.0 </vortex_currents>

        <!-- Global sinusoidal (tidal-like) current -->
        <global_waves>
            <wave1>
                <amplitude> 0.06 </amplitude>
                <frequency> 0.05 </frequency>
                <direction> 90.0 </direction>
                <shift> 1.0 </shift>
            </wave1>
        </global_waves>

        <!-- Space + time dependent waves -->
        <local_waves>
            <wave1>
                <amplitude> 0.06 </amplitude>
                <wavelength> 200.0 </wavelength>
                <wavespeed> 0.1 </wavespeed>
                <direction> 60.0 </direction>
                <shift> 1.0 </shift>
            </wave1>
        </local_waves>

        <!-- Ekman spiral: wind-driven current rotating with depth.
             Latitude set to the Abu Dhabi reference 24.5 degN. -->
        <current_3d>
            <model>ekman</model>
            <wind_speed>5.0</wind_speed>
            <wind_direction>315.0</wind_direction>
            <latitude>24.5</latitude>
            <eddy_viscosity>0.01</eddy_viscosity>
        </current_3d>

    </environment_setup>

    <!-- Optional Field: Describe start-up agents and add them to the simulation -->
    <agents>
        <agent_type>
            <description>agent.xml</description>
            <name>A</name>
            <state>
                <!-- Initial state, one line for each agent -->
                <!-- x, y, z, psi -->
                0.0  0.0  69.0  46.0
                3.0  0.0  69.0  180.0
                <!-- Add more lines to add agents -->
            </state>
        </agent_type>
    </agents>

    <seed>
        111
    </seed>

</data>
